{
  "name": "med-exam-public",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "node scripts/dev-server.mjs",
    "typecheck": "tsc -b",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse:sample": "python scripts/exams/build_dataset.py --questions scripts/exams/fixtures/sample_question_text.txt --answers scripts/exams/fixtures/sample_answer_text.txt --year 115-1 --subject physician-stage-1-basic --out public/data/exams/115-1/physician-stage-1-basic.json",
    "download:moex:115-1": "python scripts/exams/download_moex.py --year 115-1 --preset physician-115-first --out-dir downloads/moex",
    "build:moex:115-1": "python scripts/exams/build_moex_preset.py --preset physician-115-first --downloads-dir downloads/moex --data-dir public/data --write-manifest",
    "export:gemini-prompts": "python scripts/exams/export_gemini_prompts.py \"public/data/exams/**/*.json\" --out-dir reports/gemini_prompts",
    "export:gemini-prompts:fresh": "python scripts/exams/export_gemini_prompts.py \"public/data/exams/**/*.json\" --out-dir reports/gemini_prompts --force",
    "import:gemini-explanations": "python scripts/exams/import_gemini_explanations.py \"reports/gemini_outputs/**/*.json\"",
    "apply:categories": "python scripts/exams/apply_category_map.py --map scripts/exams/category_ranges.json",
    "validate:data": "python scripts/exams/validate_dataset.py \"public/data/exams/**/*.json\" --out reports/dataset-quality.json",
    "validate:explanations": "python scripts/exams/validate_explanations.py \"public/data/exams/**/*.json\" --out reports/explanation-quality.json",
    "content:trust": "node scripts/exams/run_python.mjs scripts/exams/audit_content_trust.py \"public/data/exams/**/*.json\" --out reports/prepromo-content-trust.json",
    "validate:content-trust": "npm run content:trust",
    "update:glossary-links": "node scripts/exams/update_medical_glossary_related_questions.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
